PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/smart_student_solution
# Atlas: include DB name before query string, URL-encode special chars in password (@ → %40, etc.)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/myappname?retryWrites=true&w=majority
# If querySrv ECONNREFUSED: try MONGODB_DNS_FAMILY=ipv4, different network/VPN, or Atlas "Drivers" non-SRV connection string
# MONGODB_DNS_FAMILY=ipv4
JWT_SECRET=change_this_to_a_long_random_string

# Optional: public URL of the React app (CORS)
CLIENT_URL=http://localhost:5173

# Nodemailer (Gmail example: use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Smart Student Solution <your_email@gmail.com>"
